# ============================================================================
# KRISHI BONDHU — CENTRAL CONFIGURATION
# Copy this file to .env and fill in your values.
# ============================================================================

# --- API KEYS ---
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_token_here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# --- LLM CONFIGURATION ---
LLM_PROVIDER=huggingface
GEMINI_MODEL=models/gemini-2.5-flash
HUGGINGFACE_MODEL=meta-llama/Llama-3.2-3B-Instruct

# --- DATABASE ---
# Docker Compose overrides this to point to the 'postgres' service.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farmdb

# --- CACHING ---
REDIS_URL=redis://localhost:6379/0

# --- EXTERNAL SERVICES ---
WEATHER_API_KEY=your_openweathermap_key_here
MARKET_API_KEY=your_dam_api_key_here
SMS_GATEWAY_KEY=your_twilio_or_bulksms_key_here
HELPLINE_NUMBER=3331
SENTINEL_HUB_KEY=your_sentinel_hub_key_here

# --- VISION MODELS (HuggingFace Inference API) ---
VISION_MODEL_ID=prof-freakenstein/plantnet-disease-detection
SOIL_VISION_MODEL_ID=google/vit-base-patch16-224
DAMAGE_VISION_MODEL_ID=google/vit-base-patch16-224

# --- SERVICES ---
STT_PROVIDER=gemini
TTS_PROVIDER=gtts

# --- APPLICATION SETTINGS ---
DEBUG=true
LOG_LEVEL=INFO
UPLOAD_DIR=/tmp/uploads
OFFLINE_MODE_ENABLED=false
