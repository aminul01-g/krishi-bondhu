# API KEYS
# ----------------------------------------------------------------------------
GEMINI_API_KEY=AIzaSyB7NjaPEnTkZh7K9q56Dhp_ishEVFH8HsY
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# LLM CONFIGURATION
# ----------------------------------------------------------------------------
LLM_PROVIDER=huggingface
GEMINI_MODEL=models/gemini-2.5-flash

# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Note: Docker Compose overrides this to point to the 'postgres' service.
# This value is for running the backend locally (outside Docker).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farmdb

# SERVICES
# ----------------------------------------------------------------------------
STT_PROVIDER=gemini
TTS_PROVIDER=gtts

# APPLICATION SETTINGS
# ----------------------------------------------------------------------------
DEBUG=true
LOG_LEVEL=INFO
UPLOAD_DIR=/tmp/uploads
