# ============================================================================
# KRISHI BONDHU - PRODUCTION ENVIRONMENT TEMPLATE
# ============================================================================

# --- API KEYS & AUTHENTICATION ---
GEMINI_API_KEY=your_gemini_key
HUGGINGFACE_API_KEY=your_hf_key
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# --- EXTERNAL SERVICE KEYS ---
WEATHER_API_KEY=your_openweather_key
MARKET_API_KEY=your_market_api_key
SENTINEL_HUB_KEY=your_sentinel_key

# --- SMS GATEWAY CONFIGURATION ---
SMS_GATEWAY_URL=your_sms_gateway_url
SMS_GATEWAY_KEY=your_sms_key
HELPLINE_PHONE_NUMBER=3331

# --- DATABASE CONFIGURATION ---
# For Docker Compose: postgresql+asyncpg://user:pass@db:5432/krishi
# For Local: postgresql+asyncpg://postgres:postgres@localhost:5432/farmdb
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/krishi

# --- REDIS CONFIGURATION ---
# For Docker Compose: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# --- LLM & AI CONFIGURATION ---
LLM_PROVIDER=huggingface
HUGGINGFACE_MODEL=microsoft/Phi-3-mini-4k-instruct
GEMINI_MODEL=models/gemini-2.5-flash
STT_PROVIDER=gemini
TTS_PROVIDER=gtts

# --- APPLICATION SETTINGS ---
DEBUG=false
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads
OFFLINE_MODE_ENABLED=false
